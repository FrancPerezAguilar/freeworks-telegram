# Free Works Mini App — variables de entorno de ejemplo.
# Copia este archivo a `.env.local` (NO committeado) y rellena los valores reales.

# Endpoint de Appwrite Cloud
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# ID del proyecto Appwrite (consola → Settings → Project ID)
VITE_APPWRITE_PROJECT_ID=6a3a9bfd00036f813523

# ID de la database
VITE_APPWRITE_DATABASE_ID=freeworks

# API key de servidor (consola → API Keys → Create API Key).
# Si expira, regenerarla y actualizar solo este valor.
VITE_APPWRITE_API_KEY=